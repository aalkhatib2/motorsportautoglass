# Copy to .env for local development. NEVER commit the real .env — it is gitignored.
# In production these are set in the Vercel dashboard:
#   Project → Settings → Environment Variables

# Twilio account credentials — Twilio Console dashboard.
# The auth token is a secret: treat it like a password, rotate it if it leaks.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# The Twilio number the SMS is sent FROM. Must be a number you own in Twilio
# and have SMS-enabled. E.164 format.
TWILIO_FROM_NUMBER=+18135550100

# The number that RECEIVES new booking alerts (Zaid's mobile). E.164 format.
# On a Twilio trial account this must be a verified number.
ZAID_PHONE_NUMBER=+18135550101
